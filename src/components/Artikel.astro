---
// Astro.props indeholder de værdier, som komponenten modtager fra index.astro.
const img = Astro.props.img;
const tag = Astro.props.tag;
const text1 = Astro.props.text1;
const text2 = Astro.props.text2;
// const { img, tag, text } = Astro.props; // Shorthand Alternativ (flottere) måde at skrive med destructuring//
---

<article>
  <!-- Her indsætter vi billedstien fra prop'en img, tag og text. -->
 <div>
  <img src={img} /></div>
 <div> <h3>{tag}</h3>
  <p id="article_text_bold">{text1}</p>
  <p>{text2}</p>
  <div class="button_article"><slot /></div></div>
</article>

<style>
  article {
    width: 90%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 30px;
  }
  
  
  .button_article {
    display: flex;
    justify-content: flex-end;
    width: 100%;
  }
  
  img {
    border-radius: 6px;
    margin-bottom: 1.3rem;
    /* height: auto;
    width: 50%; */
  }

  h3 {
    margin-bottom: 0.56rem;
  }

  p {
    margin-bottom: 1.3rem;
  }

  #article_text_bold {
    font-weight: bold;
  }


@media (min-width: 800px) {
  article {
 display: grid;
    /* flex-direction: column; */
    align-items: start;
    justify-content: left;
    grid-template-columns: 1fr 2fr;
    /* grid-template-rows: 1fr; */
    gap: 2rem;
  }
  
  .button_article {
    justify-content: flex-end;
  }

 /* grid-template-columns: 1fr 2fr; */
  

img{
   height: auto;
    width: 100%;
    /* order: -1; */
}
section{
  display: grid;
  grid-template-columns: 2fr;
  gap: 1rem;
}}
  
</style>
