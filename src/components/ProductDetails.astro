---
const {product} = Astro.props;
---

<section>

<img src={product.images} alt="">
<article>
<div class="brandsection">
    <h2>{product.brand}</h2>
    <h3>{product.title}</h3>
    <p>Bedst før: {product.bestbefore}</p>
    <p>{product.alcoholperc}% type øl</p>
    <p class="green">Lagerstatus</p>
</div>
<div class="tastesection">
<h3>Smagen</h3>
<p>{product.description}</p>
    <h4>Øllens farve (SRM)</h4>
    <img src="../public/imgs/beerscale.svg" alt="Øl skala">
    <p id="arrow">pil her</p>
    <h4>Untapped rating: {product.rating}</h4>
</div>

<div class="pricesection">
    <p class="green">1 stk.</p>
<div class="pricetop green">
    <p>Besparelse i kroner</p>
    <p>{product.price} DKK/stk.</p>
</div>
<div class="pricebottom">
<p class="vejl">{product.beforeprice} DKK (vejl. markedspris)</p>
</div>
</div>

<div class="pricesection">
    <p class="green">6 stk.</p>
<div class="pricetop green">
    <p>Besparelse i kroner</p>
    <p>{product.pricepack} DKK/stk.</p>
</div>
<div class="pricebottom">
<p class="vejl">{product.beforepricepack} DKK (vejl. markedspris)</p>
<p>Pris DKK total</p>
</div>
</div>
<p>Knap her</p>
</article>

</section>

<style>
    article {
        border: solid 3px var(--grey);
        padding: 2rem;
    }

    .pricesection {
        border-top: double 3px var(--black);
        border-bottom: double 3px var(--black);
        margin-top: 16px;
    }

    .pricesection p {
        margin-top: 4px;
        margin-bottom: 4px;
    }

    .pricetop, .pricebottom {
        display: flex;
        justify-content: space-between;
    }

    h2, h3 {
        margin-bottom: 8px;
    }

    .brandsection p {
        margin-bottom: 8px;
    }

    .tastesection h4 {
        margin-top: 16px;
        margin-bottom: 8px;
    }

    #arrow {
        margin-top: 8px;
        margin-bottom: 16px;
    }

    section {
        padding-left: 1.5rem;
        padding-right: 1.5rem;
    }

    .green {
        color: var(--primary);
    }

    .vejl {
        color: var(--grey);
        text-decoration: line-through;
    }
</style>