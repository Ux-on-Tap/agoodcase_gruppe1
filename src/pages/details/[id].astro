  <div id="product-data" data-fisk={product.category}></div>
</Layout>

<style>

  section {
    background-image: url(/public/imgs/seamless_grid13.svg);
    background-size: contain;
    background-repeat: repeat-y;
    width: 90vw;
    border: solid 3px var(--grey);
    margin: 64px auto;
    display: grid;
  }

  article {
    border: solid 3px var(--grey);
    padding: 2rem;
    background-color: var(--true-white);
    margin: 32px 32px 32px 32px;
  }

  .pricesection {
    border-top: double 3px var(--black);
    border-bottom: double 3px var(--black);
    margin-top: 16px;
  }

  .pricesection p {
    margin-top: 4px;
    margin-bottom: 4px;
  }

  .pricetop,
  .pricebottom {
    display: flex;
    justify-content: space-between;
  }

  h2,
  h3 {
    margin-bottom: 8px;
  }

  .brandsection p {
    margin-bottom: 8px;
  }

  .tastesection h4 {
    margin-top: 16px;
    margin-bottom: 8px;
  }

  .arrow {
    width: 1rem;
  }
  #arrowwrap {
    display: flex;
    justify-content: space-between;
    width: 100%;
    margin-top: 0px;
    margin-bottom: 16px;
    padding: 0 6px;
  }

  .green {
    color: var(--primary);
  }

  .vejl {
    color: var(--grey);
    text-decoration: line-through;
  }

  .path {
    fill: var(--primary);
  }

  .hide {
    fill: var(--true-white);
  }

  body {
    background-color: var(--white);
  }
  
  .ansvar {
    border-top: double 3px var(--black);
    border-bottom: double 3px var(--black);
    width: 90vw;
    margin: 96px 5vw;
  }

@media (min-width: 800px) {
  article {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 64px;
    margin: 32px 32px 32px 8px;
  }
  #productimg {
    margin-top: 32px;
  }

  section {
    display: grid;
    grid-template-columns: 1fr 2fr;
  }

  .right {
    display: flex;
    flex-direction: column;
  }

#knap {
  display: flex;
  height: stretch;
  justify-content: end;
  align-items: end;
}

#arrowwrap {
  padding: 0px 2px;
}

}

</style>

<script define:vars={{product}}>
// Script til at vælge hvilken pil der skal vises på skalaen

  function showarrow(e) {
    const arrows = document.querySelectorAll(".path");
    const productcategory = product.category;
    
    arrows.forEach((arrow) => {
      
      if (productcategory.includes(arrow.dataset.category)) {
        arrow.classList.remove("hide");
      } else {
        arrow.classList.add("hide");
      }

    }
  
  );
  }

  showarrow();

</script>
