---
//@ts-nocheck
import Layout from "../../layouts/Layout.astro";
import ProductDetails from "../../components/ProductDetails.astro";
import AddToBasket from "../../components/AddToBasket.astro";
export async function getStaticPaths() {
  const endpoint =
    "https://phmyuxewmvhrkzgmjrtw.supabase.co/rest/v1/Datastruktur_produkter?select=*";

  const options = {
    headers: { apikey: "sb_publishable_vji-RnXHn3KkTNJ4KqYoxA_HzS1mbaj" },
  };
  const response = await fetch(endpoint, options);
  const data = await response.json();

  return data.map((product) => {
    return {
      params: { id: product.handle },
      props: { product },
    };
  });
}

const { product } = Astro.props;
---

<Layout>
  <section>
    <img src={product.images} alt="produktbillede" />
    <article>
      <div class="left">
      <div class="brandsection">
        <h2>{product.brand}</h2>
        <h3>{product.title}</h3>
        <p>Bedst før: {product.bestbefore}</p>
        <p>{product.alcoholperc}% {product.category}</p>
        <p class="green">Lagerstatus</p>
      </div>
      <div class="tastesection">
        <h3>Smagen</h3>
        <p>{product.description}</p>
        <h4>Øllens farve (SRM)</h4>
        <img src="../public/imgs/beerscale.svg" alt="Øl skala" />
        <p id="arrow">pil her</p>
        <h4>Untapped rating: {product.rating}</h4>
      </div>
      </div>

      <div class="right">
      <div class="pricesection">
        <p class="green">1 stk.</p>
        <div class="pricetop green">
          <p>Besparelse</p>
          <p>{product.price} DKK/stk.</p>
        </div>
        <div class="pricebottom">
          <p class="vejl">{product.beforeprice} DKK (vejl. markedspris)</p>
        </div>
      </div>

      <div class="pricesection">
        <p class="green">6 stk.</p>
        <div class="pricetop green">
          <p>Besparelse</p>
          <p>{product.price} DKK/stk.</p>
        </div>
        <div class="pricebottom">
          <p class="vejl">{product.beforepricepack} DKK (vejl. markedspris)</p>
          <p>{product.pricepack} DKK total</p>
        </div>
      </div>
      <div id="knap">
      <AddToBasket></AddToBasket>
      </div>
      </div>
    </article>
  </section>
</Layout>

<style>
  article {
    border: solid 3px var(--grey);
    padding: 2rem;
  }

  .pricesection {
    border-top: double 3px var(--black);
    border-bottom: double 3px var(--black);
    margin-top: 16px;
  }

  .pricesection p {
    margin-top: 4px;
    margin-bottom: 4px;
  }

  .pricetop,
  .pricebottom {
    display: flex;
    justify-content: space-between;
  }

  h2,
  h3 {
    margin-bottom: 8px;
  }

  .brandsection p {
    margin-bottom: 8px;
  }

  .tastesection h4 {
    margin-top: 16px;
    margin-bottom: 8px;
  }

  #arrow {
    margin-top: 8px;
    margin-bottom: 16px;
  }

  section {
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .green {
    color: var(--primary);
  }

  .vejl {
    color: var(--grey);
    text-decoration: line-through;
  }

@media (min-width: 800px) {
  article {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 64px;
  }

  section {
    display: grid;
    grid-template-columns: 1fr 2fr;
  }

  .right {
    display: flex;
    flex-direction: column;
  }

#knap {
  display: flex;
  height: stretch;
  justify-content: end;
  align-items: end;
}

}

</style>
